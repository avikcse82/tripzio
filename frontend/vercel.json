{
  "functions": {
    "api/seo-destination.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/:path*-trip-planner",
      "destination": "/api/seo-destination"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
